# Copy to .env on the EC2 host and fill in real values. NEVER commit the real .env.
#
# RDS Postgres connection string (from the RDS console → Connectivity).
DATABASE_URL=postgresql://pc_tool:CHANGE_ME@your-rds-endpoint.abc123.us-east-1.rds.amazonaws.com:5432/pc_tool

# S3 bucket for uploaded workbooks + the pickle cache.
S3_BUCKET=pc-tool-uploads-CHANGE_ME
S3_PREFIX=uploads/

# AWS region (match your RDS + S3 + EC2 region).
AWS_REGION=us-east-1

# Optional: only needed if the browser ever calls the backend cross-origin.
# With the same-domain ALB setup you can leave this blank.
FRONTEND_URL=
